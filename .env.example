# CrossCoders — environment variables (TEMPLATE)
#
# HOW THIS WORKS:
#   • For LOCAL dev: copy this file to `.env` and paste your keys there.
#       cp .env.example .env
#     `.env` is gitignored, so real keys are NEVER committed.
#   • For PRODUCTION (Cloudflare Pages): do NOT put real keys in any file.
#     Set them as encrypted Pages secrets instead (see PAYSTACK-SETUP.md):
#       npx wrangler pages secret put PAYSTACK_SECRET_KEY --project-name crosscoders
#
# The secret key is server-only. It is read by the functions in
# functions/api/paystack/* and never sent to the browser.

# ─── Paystack ─────────────────────────────────────────────────────────────
# Paystack Dashboard → Settings → API Keys & Webhooks.
# IMPORTANT: rotate ("Generate new secret key") before first use if the old
# key was ever shared/screenshotted, then paste the NEW secret key here.
PAYSTACK_SECRET_KEY=<paste your rotated secret key here — starts with sk_live_ >

# Public key — only needed if you switch to Paystack inline/popup later.
# The current server-redirect flow does NOT use it, so it can stay blank.
PAYSTACK_PUBLIC_KEY=<optional public key — starts with pk_live_ >

# ─── Existing integrations (already live — leave as-is unless changing) ────
# BREVO_API_KEY=
# OPENAI_API_KEY=
# APPLY_TO=
# APPLY_FROM=
