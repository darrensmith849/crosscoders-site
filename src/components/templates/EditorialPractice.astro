---
const stats = [
  ['Fit', 'Expert-led practices'],
  ['Tone', 'Quietly premium'],
  ['Proof', 'Case-led'],
  ['Intake', 'Consultation-ready'],
];

const principles = [
  ['Considered', 'Every engagement starts with clear diagnosis, context and a useful point of view.'],
  ['Crafted', 'The page gives space to strategy, visual judgement, process and practical delivery.'],
  ['Lasting', 'The design is restrained enough to hold up after the first impression has passed.'],
];

const services = [
  ['Strategy', 'Positioning, discovery, service framing and decision support for important moves.'],
  ['Design', 'Identity, digital systems, editorial direction and communication that feels considered.'],
  ['Advisory', 'Senior guidance for teams who need perspective before they commit to a direction.'],
  ['Delivery', 'Implementation support, documentation, supplier coordination and launch structure.'],
  ['Audit', 'A calm assessment of what works, what is weak and what should change next.'],
  ['Support', 'Ongoing retainers, workshops and improvement cycles after the first piece of work ships.'],
];

const cases = [
  {
    name: 'Northline advisory system',
    type: 'Strategy / Delivery',
    text: 'A sharper operating model for a leadership team with too many moving parts and no clear sequence.',
    image: '/img/templates/editorial-practice/worktable.jpg',
  },
  {
    name: 'Atelier practice launch',
    type: 'Identity / Digital',
    text: 'A clean presence for a specialist studio that needed credibility without looking overproduced.',
    image: '/img/templates/editorial-practice/blueprints.jpg',
  },
  {
    name: 'Civic service review',
    type: 'Audit / Advisory',
    text: 'A practical review that turned scattered evidence into priorities the team could actually act on.',
    image: '/img/templates/editorial-practice/collaboration.jpg',
  },
];

const journal = [
  ['How to frame a complex brief', 'A short note on turning unclear requirements into a decision-ready project frame.'],
  ['What a good audit should reveal', 'Where evidence, risk, gaps and useful next actions should meet.'],
  ['Why delivery still needs taste', 'The difference between simply finishing work and leaving something coherent behind.'],
];

const images = {
  worktable: '/img/templates/editorial-practice/worktable.jpg',
  blueprints: '/img/templates/editorial-practice/blueprints.jpg',
};
---

<div class="tpl-page ep-page">
  <nav class="template-nav ep-nav" aria-label="Editorial Practice navigation">
    <a href="/templates">Editorial Practice</a>
    <div>
      <a href="#ep-services">Services</a>
      <a href="#ep-cases">Cases</a>
      <a href="#ep-consult">Consultation</a>
    </div>
  </nav>

  <section class="ep-hero">
    <div class="ep-hero-copy" data-reveal>
      <p class="tpl-eyebrow">Independent practice</p>
      <h1>Clear thinking, carefully delivered.</h1>
      <p>For consultants, studios and expert-led firms that need trust, taste and a quiet body of proof.</p>
      <div class="tpl-actions">
        <a class="tpl-btn primary" href="#ep-consult">Start a project</a>
        <a class="tpl-btn ghost" href="#ep-services">View services</a>
      </div>
    </div>
    <article class="ep-featured" data-reveal>
      <figure class="ep-image">
        <img src={images.worktable} alt="Plans and working materials arranged on a studio table" />
      </figure>
      <p>Featured project</p>
      <h2>Northline advisory system</h2>
      <dl>
        <div><dt>Category</dt><dd>Strategy / Delivery</dd></div>
        <div><dt>Year</dt><dd>2026</dd></div>
        <div><dt>Outcome</dt><dd>Sharper operating model</dd></div>
      </dl>
    </article>
  </section>

  <section class="ep-stat-row" aria-label="Practice stats">
    {stats.map(([label, value]) => <p data-reveal><span>{label}</span><strong>{value}</strong></p>)}
  </section>

  <section class="tpl-section ep-about">
    <div data-reveal>
      <p class="tpl-eyebrow">Philosophy</p>
      <h2>Expert work should feel calm, legible and deeply considered.</h2>
    </div>
    <div class="ep-about-copy" data-reveal>
      <p>Credibility is built through restraint: a clear point of view, visible evidence and enough process for the right client to understand how decisions are made.</p>
      <figure>
        <img src={images.blueprints} alt="Detailed project documents and notes spread across a desk" loading="lazy" />
        <figcaption>Evidence, structure and taste in the same frame.</figcaption>
      </figure>
    </div>
  </section>

  <section class="tpl-section ep-principles">
    {principles.map(([title, text], index) => (
      <article data-reveal>
        <span>{String(index + 1).padStart(2, '0')}</span>
        <h3>{title}</h3>
        <p>{text}</p>
      </article>
    ))}
  </section>

  <section class="tpl-section ep-services" id="ep-services">
    <div class="tpl-section-head" data-reveal>
      <p class="tpl-eyebrow">Services</p>
      <h2>Six ways the practice can help.</h2>
    </div>
    <div class="ep-service-list">
      {services.map(([title, text], index) => (
        <details data-reveal open={index === 0}>
          <summary>{title}</summary>
          <p>{text}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="tpl-section ep-cases" id="ep-cases">
    <div class="tpl-section-head" data-reveal>
      <p class="tpl-eyebrow">Case studies</p>
      <h2>Selected work index.</h2>
    </div>
    <div class="ep-case-grid">
      {cases.map((item, index) => (
        <article data-reveal>
          <img src={item.image} alt="" loading="lazy" />
          <span>0{index + 1}</span>
          <h3>{item.name}</h3>
          <p class="ep-case-type">{item.type}</p>
          <p>{item.text}</p>
          <a href="#ep-consult">View outline</a>
        </article>
      ))}
    </div>
  </section>

  <section class="ep-quote" data-reveal>
    <blockquote>
      <p>"The strongest professional sites do not shout. They clarify why the practice should be trusted."</p>
      <cite>Principal note</cite>
    </blockquote>
  </section>

  <section class="tpl-section ep-journal">
    <div class="tpl-section-head" data-reveal>
      <p class="tpl-eyebrow">Journal</p>
      <h2>Insights that prove how the team thinks.</h2>
    </div>
    <div class="ep-journal-grid">
      {journal.map(([title, text]) => (
        <article data-reveal>
          <span>Insight</span>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="ep-consult" id="ep-consult" data-reveal>
    <div>
      <p class="tpl-eyebrow">Consultation</p>
      <h2>Start with a clear first conversation.</h2>
      <p>Share the context, the decision in front of you and what needs to become clearer.</p>
    </div>
    <form onsubmit="return false">
      <label>Name<input type="text" name="name" /></label>
      <label>Email<input type="email" name="email" /></label>
      <label>Project type<input type="text" name="project-type" /></label>
      <label>Message<textarea name="message" rows="4"></textarea></label>
      <button type="submit">Request consultation</button>
    </form>
  </section>
</div>
