---
// Live analytics dashboard: counting KPIs, drawing chart, streaming activity. Animated by src/scripts/demos.js.
interface Props { url?: string }
const { url = 'grace.app/dashboard' } = Astro.props;
---
<div class="browser" data-demo="dash">
  <div class="bbar"><span class="dot" style="background:#E06A57"></span><span class="dot" style="background:#E8B84B"></span><span class="dot" style="background:#3FD174"></span><span class="url">{url}</span></div>
  <div class="dash">
    <div class="kpis">
      <div class="kpi"><div class="kl">Members</div><div class="kv" data-to="2480">0</div><div class="kd">▲ 38 this week</div></div>
      <div class="kpi"><div class="kl">Given / mo</div><div class="kv" data-to="18420" data-pre="$">$0</div><div class="kd">▲ 12%</div></div>
      <div class="kpi"><div class="kl">Engaged</div><div class="kv" data-to="92" data-suf="%">0%</div><div class="kd">▲ 4 pts</div></div>
    </div>
    <div class="dchart">
      <div class="dh"><span>Weekly engagement</span><span style="color:var(--forest-deep)">+18%</span></div>
      <svg viewBox="0 0 320 118" preserveAspectRatio="none">
        <defs><linearGradient id="ag" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#13B24A" stop-opacity=".22"/><stop offset="1" stop-color="#13B24A" stop-opacity="0"/></linearGradient></defs>
        <path class="darea" d="M0 94 L46 76 L91 82 L137 52 L183 60 L229 32 L274 42 L320 22 L320 118 L0 118 Z" fill="url(#ag)" opacity="0" style="transition:opacity .7s .7s"/>
        <path class="dline" d="M0 94 L46 76 L91 82 L137 52 L183 60 L229 32 L274 42 L320 22" fill="none" stroke="#13B24A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        <g><circle class="pt" cx="91" cy="82" r="3.5" fill="#C9A961"/><circle class="pt" cx="183" cy="60" r="3.5" fill="#C9A961"/><circle class="pt" cx="274" cy="42" r="3.5" fill="#C9A961"/></g>
      </svg>
    </div>
    <div class="dact">
      <div class="actrow"><span class="ad"></span><span><b>New member</b> · Sarah M. joined</span><span class="at">now</span></div>
      <div class="actrow"><span class="ad"></span><span><b>$50 gift</b> · General Fund</span><span class="at">2m</span></div>
      <div class="actrow"><span class="ad"></span><span><b>Event signup</b> · Youth camp · +3</span><span class="at">5m</span></div>
    </div>
  </div>
</div>
