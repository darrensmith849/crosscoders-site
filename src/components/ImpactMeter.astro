---
// Interactive impact "heat bar" for the Foundation. Maps giving -> churches -> people,
// with a live "your gift" projection. Figures come from `give` in content.ts and are
// illustrative until real build costs are set. In pledge mode (current = 0) it invites
// people to be the first; the give button registers interest (no live payment yet).
import { give } from '../lib/content';
const kfmt = (n: number) => (n >= 1000 ? '$' + n / 1000 + 'k' : '$' + n);
const tierPos = give.tiers.map((_, i) => Math.round(((i + 1) / give.tiers.length) * 100));
---
<section class="impact oak">
  <div class="wrap">
    <div class="im-card">
      <div class="im-top">
        <span class="eyebrow">The Foundation · our goal</span>
        <span class="im-multi">AI leverage — every $1 does ~$10 of work</span>
      </div>
      <div class="im-head" id="im-head">Help under-resourced churches get online.</div>
      <div class="im-track"><div class="im-fill" id="im-fill"></div><div class="im-ghost" id="im-ghost"></div></div>
      <div class="im-tiers" id="im-tiers">
        {give.tiers.map((t) => (
          <div class="im-tier"><b>{kfmt(t.amount)}</b>{t.label}</div>
        ))}
      </div>
      <div class="im-hr"></div>
      <div class="im-giveh">See what your gift would do:</div>
      <div class="im-chips" id="im-chips">
        <button type="button" class="im-chip" data-v="25">$25</button>
        <button type="button" class="im-chip" data-v="50">$50</button>
        <button type="button" class="im-chip on" data-v="100">$100</button>
        <button type="button" class="im-chip" data-v="250">$250</button>
      </div>
      <div class="im-sld"><input type="range" id="im-range" min="10" max="1000" step="10" value="100" aria-label="Gift amount" /><span class="im-amt" id="im-amt">$100</span></div>
      <div class="im-impact" id="im-impact">Your $100 would help reach more people on the way to the next free church build.</div>
      <a class="btn btn-primary im-give" href="/foundation/support" id="im-give">Pledge $100 <span class="arrow">→</span></a>
      <p class="im-note">Giving opens once the Foundation is registered — pledge now and we'll be in touch. Tiers are illustrative until real build costs are confirmed.</p>
    </div>
  </div>
</section>

<script define:vars={{ give, tierPos }}>
  (function () {
    const goal = give.goal, current = give.current, cpb = give.costPerBuild, ppb = give.peoplePerBuild;
    const totalCh = Math.floor(goal / cpb);
    const flags = [{ a: 0, p: 0 }].concat(give.tiers.map((t, i) => ({ a: t.amount, p: tierPos[i] })));
    function pos(a) { a = Math.max(0, Math.min(a, goal)); for (let i = 1; i < flags.length; i++) { if (a <= flags[i].a) { const p = flags[i - 1], q = flags[i]; return p.p + (a - p.a) / (q.a - p.a) * (q.p - p.p); } } return 100; }
    const curPos = pos(current);
    const fill = document.getElementById('im-fill'), ghost = document.getElementById('im-ghost'), head = document.getElementById('im-head'), impact = document.getElementById('im-impact'), amt = document.getElementById('im-amt'), range = document.getElementById('im-range'), giveBtn = document.getElementById('im-give'), tiers = document.getElementById('im-tiers').children, chips = document.getElementById('im-chips').children;
    if (!fill) return;
    fill.style.width = curPos + '%';
    function update(g) {
      const proj = current + g, pp = pos(proj), churches = Math.floor(proj / cpb);
      ghost.style.left = curPos + '%'; ghost.style.width = Math.max(0, pp - curPos) + '%';
      if (proj <= 0) head.innerHTML = 'Be the <b>first</b> to fuel a build.';
      else if (churches < 1) head.innerHTML = 'Your gift gets us started — <b>$' + proj.toLocaleString() + '</b> toward the first church.';
      else head.innerHTML = '<b>$' + proj.toLocaleString() + '</b> raised · ' + Math.min(churches, totalCh) + ' of ' + totalCh + ' churches online.';
      for (let i = 0; i < tiers.length; i++) tiers[i].classList.toggle('on', proj >= give.tiers[i].amount);
      const people = Math.round(g * ppb / cpb);
      impact.innerHTML = 'Your <b>$' + g.toLocaleString() + '</b> would help reach about <b>' + people + ' people</b> — on the way to the next free church build.';
      amt.textContent = '$' + g.toLocaleString(); range.value = g; giveBtn.innerHTML = 'Pledge $' + g.toLocaleString() + ' <span class="arrow">→</span>';
      for (let j = 0; j < chips.length; j++) chips[j].classList.toggle('on', +chips[j].dataset.v === g);
    }
    range.addEventListener('input', () => update(+range.value));
    for (let k = 0; k < chips.length; k++) chips[k].addEventListener('click', function () { update(+this.dataset.v); });
    update(100);
  })();
</script>
