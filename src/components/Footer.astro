---
import { brand, products } from '../lib/content';
import Mark from './Mark.astro';
---

<footer>
  <div class="wrap">
    <div class="f-top">
      <div class="f-brand">
        <a class="brand" href="/"><Mark /><span class="brand-tx"><span class="brand-name">{brand.name}</span><span class="brand-sub">{brand.org}</span></span></a>
        <p>A Christian nonprofit — we build apps, websites and AI, and give them free to churches and Christian organisations.</p>
        <span class="f-badge">A Christian nonprofit · Christ, code &amp; coffee</span>
        <a class="f-email" href={brand.contactHref}>Get in touch</a>
      </div>
      <div class="f-col">
        <h5>Build</h5>
        {products.map((p) => <a href={`/services/${p.slug}`}>{p.name}</a>)}
      </div>
      <div class="f-col">
        <h5>Explore</h5>
        <a href="/ai">Our approach</a>
        <a href="/process">How we work</a>
        <a href="/work">Work</a>
        <a href="/about">About</a>
        <a href="/insights">Insights</a>
        <a href="/faq">FAQ</a>
      </div>
      <div class="f-col">
        <h5>The Foundation</h5>
        <a href="/give">Fuel a build</a>
        <a href="/foundation/queue">Funded projects</a>
        <a href="/foundation/apply">Apply for a build</a>
        <a href="/foundation/support">Support the mission</a>
        <a href="/contact">Contact</a>
      </div>
    </div>
    <div class="f-bottom">
      <span>© 2026 {brand.name}. A Christian nonprofit.</span>
      <span class="verse">{brand.verse}</span>
    </div>
    <div class="f-bottom f-legal">
      <span><a href="/privacy">Privacy</a> · <a href="/terms">Terms</a> · Built with {brand.builtWith}</span>
      <span>We'll never sell your details.</span>
    </div>
  </div>
</footer>
