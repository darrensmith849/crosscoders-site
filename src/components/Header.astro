---
import { ctas, brand, products } from '../lib/content';
import { segments } from '../lib/pages';
import Mark from './Mark.astro';

const icons: Record<string, string> = {
  app: '<rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18M8 21h8"/>',
  web: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/>',
  agent: '<rect x="4" y="7" width="16" height="12" rx="3"/><path d="M12 7V4M9 13h.01M15 13h.01"/>',
  chat: '<path d="M21 12a8 8 0 0 1-11.5 7.2L4 20l1-4.5A8 8 0 1 1 21 12z"/>',
  auto: '<path d="M4 7h10a4 4 0 0 1 0 8H8a4 4 0 0 0 0 8"/><circle cx="18" cy="7" r="2.4"/><circle cx="6" cy="19" r="2.4"/>',
  code: '<path d="M8 9l-4 3 4 3M16 9l4 3-4 3M13 6l-2 12"/>',
  church: '<path d="M5 21V10l7-5 7 5v11"/><path d="M9 21v-5h6v5"/><path d="M12 2.5v3M10.5 4h3"/>',
  people: '<circle cx="7.5" cy="9.5" r="2.3"/><circle cx="16.5" cy="9.5" r="2.3"/><circle cx="12" cy="15" r="2.3"/>',
  growth: '<path d="M4 19V5M4 19h16"/><path d="M7 15l3-3 3 2 5-6"/>',
  briefcase: '<rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M3 12h18"/>',
  ai: '<rect x="6" y="6" width="12" height="12" rx="3"/><path d="M9 2v3M15 2v3M9 19v3M15 19v3M2 9h3M2 15h3M19 9h3M19 15h3"/>',
  route: '<circle cx="6" cy="6" r="2.5"/><circle cx="18" cy="18" r="2.5"/><path d="M8.5 6H15a3 3 0 0 1 0 6H9a3 3 0 0 0 0 6h6.5"/>',
  heart: '<path d="M12 21s-7-4.5-7-10a4 4 0 0 1 7-1.5A4 4 0 0 1 19 11c0 5.5-7 10-7 10z"/>',
  doc: '<path d="M14 3v5h5"/><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M9 13h6M9 17h4"/>',
  gift: '<path d="M20 12v9H4v-9"/><path d="M2 7h20v5H2z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>',
  users: '<circle cx="9" cy="8" r="3"/><path d="M3 20a6 6 0 0 1 12 0"/><path d="M16 6a3 3 0 0 1 0 6M21 20a6 6 0 0 0-4-5.6"/>',
  star: '<path d="M12 3l2.6 5.6L20 9.3l-4 4 1 6-5-3-5 3 1-6-4-4 5.4-.7z"/>',
  book: '<path d="M5 4a2 2 0 0 1 2-2h11v16H7a2 2 0 0 0-2 2z"/><path d="M8 7h7M8 11h7"/>',
  help: '<circle cx="12" cy="12" r="9"/><path d="M9.5 9.5a2.5 2.5 0 0 1 4.5 1.4c0 1.5-2 2-2 3.1M12 17h.01"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
};

const productDesc: Record<string, string> = {
  'web-mobile-apps': 'Apps, platforms & portals',
  'websites': 'Sites your team can run',
  'ai-agents': 'AI that does the work',
  'chatbots': 'Always-on, grounded answers',
  'automation': 'Connect tools, cut busywork',
  'custom-software': 'Platforms, APIs, MVPs',
};
const segIcon: Record<string, string> = { churches: 'church', ministries: 'people', nonprofits: 'growth', business: 'briefcase' };

interface Item { name: string; href: string; icon: string; desc?: string }
const groups: { label: string; items: Item[] }[] = [
  { label: 'What we build', items: products.map((p) => ({ name: p.name, href: `/services/${p.slug}`, icon: p.icon, desc: productDesc[p.slug] })) },
  { label: 'Who we serve', items: segments.map((s) => ({ name: s.label.replace('For ', ''), href: `/for/${s.slug}`, icon: segIcon[s.slug] })) },
  { label: 'Our approach', items: [ { name: 'Our approach to AI', href: '/ai', icon: 'ai' }, { name: 'How we work', href: '/process', icon: 'route' } ] },
  { label: 'Foundation', items: [ { name: 'The Foundation', href: '/foundation', icon: 'heart' }, { name: 'Apply for a build', href: '/foundation/apply', icon: 'doc' }, { name: 'Support the mission', href: '/foundation/support', icon: 'gift' } ] },
  { label: 'Studio', items: [ { name: 'About us', href: '/about', icon: 'users' }, { name: 'Our work', href: '/work', icon: 'star' }, { name: 'Insights', href: '/insights', icon: 'book' }, { name: 'FAQ', href: '/faq', icon: 'help' }, { name: 'Contact', href: '/contact', icon: 'mail' } ] },
];
---

<header>
  <div class="wrap">
    <nav>
      <a class="brand" href="/"><Mark />{brand.name}</a>
      <div class="nav-links">
        {groups.map((g) => (
          <div class="nav-item">
            <button type="button" class="nav-top" aria-haspopup="true" aria-expanded="false">{g.label} <span class="chev" aria-hidden="true">▾</span></button>
            <div class="dropdown">
              {g.items.map((it) => (
                <a class="dd-item" href={it.href}>
                  <span class="dd-ic"><svg viewBox="0 0 24 24" set:html={icons[it.icon]}></svg></span>
                  <span class="dd-tx"><b>{it.name}</b>{it.desc && <i>{it.desc}</i>}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="nav-cta">
        <a class="btn btn-ghost" href={ctas.primary.href}>{ctas.primary.label}</a>
        <a class="btn btn-primary magnetic" href={ctas.fund.href}>{ctas.fund.label}</a>
      </div>
      <button type="button" class="burger" aria-label="Open menu" aria-expanded="false"><span></span><span></span><span></span></button>
    </nav>
  </div>
</header>

<div class="msheet" id="msheet">
  {groups.map((g) => (
    <details class="m-group">
      <summary>{g.label}<span class="m-chev" aria-hidden="true">▾</span></summary>
      <div class="m-items">
        {g.items.map((it) => (
          <a href={it.href}><span class="dd-ic"><svg viewBox="0 0 24 24" set:html={icons[it.icon]}></svg></span>{it.name}</a>
        ))}
      </div>
    </details>
  ))}
  <div class="msheet-cta">
    <a class="btn btn-ghost" href={ctas.primary.href}>{ctas.primary.label}</a>
    <a class="btn btn-primary" href={ctas.fund.href}>{ctas.fund.label} <span class="arrow">→</span></a>
  </div>
</div>
