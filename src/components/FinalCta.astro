---
import { ctas } from '../lib/content';
interface Props { title?: string; sub?: string; }
const {
  title = "Let's build something that matters.",
  sub = "Tell us what you need — an app, a site, an agent, or all three. No pressure, no hard sell.",
} = Astro.props;
---

<section class="sec cta oak">
  <div class="wrap">
    <h2 class="serif">{title}</h2>
    <p>{sub}</p>
    <div class="hero-cta">
      <a class="btn btn-primary" href={ctas.primary.href}>{ctas.primary.label} <span class="arrow">→</span></a>
    </div>
  </div>
</section>
