---
// Line-art accents — botanical (coffee branch / leaf / bean / fern) and Christian
// (cross / dove / olive branch). Stroke uses currentColor so a parent colour +
// opacity controls how it reads. Decorative only.
type Kind = 'branch' | 'fern' | 'leaf' | 'bean' | 'cross' | 'dove' | 'olive';
interface Props { kind?: Kind; class?: string }
const { kind = 'branch', class: cls = '' } = Astro.props;

const fern = (() => {
  const leaflets = [[230, 28], [200, 26], [170, 24], [140, 21], [110, 18], [84, 14], [60, 10], [40, 6]];
  return '<path d="M40 258 Q 38 200, 40 130 Q 42 70, 40 26"/>' +
    leaflets.map(([y, l]) => `<path d="M40 ${y} Q ${40 - l * 0.6} ${y - 4}, ${40 - l} ${y - 10}"/><path d="M40 ${y} Q ${40 + l * 0.6} ${y - 4}, ${40 + l} ${y - 10}"/>`).join('');
})();

const paths: Record<Kind, string> = {
  branch: '<path d="M60 258 Q 58 180, 60 100 Q 62 60, 60 30"/><path d="M60 215 Q 35 218, 12 200 Q 30 215, 60 215 Z"/><path d="M60 215 L 18 205"/><path d="M60 215 Q 85 218, 108 200 Q 90 215, 60 215 Z"/><path d="M60 215 L 102 205"/><path d="M60 165 Q 38 170, 18 155 Q 35 165, 60 165 Z"/><path d="M60 165 L 24 158"/><path d="M60 165 Q 82 170, 102 155 Q 85 165, 60 165 Z"/><path d="M60 165 L 96 158"/><path d="M60 115 Q 42 118, 26 108 Q 40 115, 60 115 Z"/><path d="M60 115 L 30 110"/><path d="M60 115 Q 78 118, 94 108 Q 80 115, 60 115 Z"/><path d="M60 115 L 90 110"/><circle cx="55" cy="56" r="6"/><circle cx="65" cy="48" r="5.5"/><circle cx="60" cy="68" r="5.5"/><path d="M55 50 L 53 42"/><path d="M65 42 L 64 35"/><path d="M60 62 L 62 54"/>',
  fern,
  leaf: '<path d="M20 4 Q 36 22, 36 50 Q 32 70, 20 76 Q 8 70, 4 50 Q 4 22, 20 4 Z"/><path d="M20 6 L 20 74"/><path d="M20 22 L 11 28"/><path d="M20 22 L 29 28"/><path d="M20 38 L 8 46"/><path d="M20 38 L 32 46"/><path d="M20 54 L 11 60"/><path d="M20 54 L 29 60"/>',
  bean: '<ellipse cx="12" cy="18" rx="9" ry="14"/><path d="M12 5 Q 14 10, 11 18 Q 10 26, 12 31"/>',
  // Latin cross — two clean strokes, round caps overlap at the crossing.
  cross: '<path d="M32 6 L 32 104"/><path d="M9 35 L 55 35"/>',
  // Dove in flight — single flowing outline, raised wing, notched tail, small beak + eye.
  dove: '<path d="M6 41 Q 15 33, 27 37 Q 30 18, 47 11 Q 53 26, 49 40 Q 71 37, 99 20 Q 80 44, 55 47 L 69 67 Q 47 61, 41 47 Q 24 50, 6 41 Z"/><path d="M6 41 L 0 36"/><circle cx="13" cy="38" r="1.3"/>',
  // Olive branch — arching stem with paired leaves and three olives.
  olive: '<path d="M8 82 Q 62 64, 120 14"/><path d="M30 72 Q 17 62, 21 48 Q 35 56, 30 72 Z"/><path d="M47 63 Q 54 49, 69 48 Q 61 64, 47 63 Z"/><path d="M62 53 Q 49 44, 53 30 Q 66 39, 62 53 Z"/><path d="M80 41 Q 87 27, 102 27 Q 93 43, 80 41 Z"/><path d="M96 30 Q 86 20, 91 7 Q 103 17, 96 30 Z"/><circle cx="40" cy="76" r="4.3"/><circle cx="66" cy="59" r="4"/><circle cx="92" cy="43" r="3.7"/>',
};
const vb: Record<Kind, string> = {
  branch: '0 0 120 260', fern: '0 0 80 260', leaf: '0 0 40 80', bean: '0 0 24 36',
  cross: '0 0 64 110', dove: '0 0 104 74', olive: '0 0 130 92',
};
const sw: Record<Kind, number> = { branch: 0.9, fern: 0.9, leaf: 0.9, bean: 1.4, cross: 2, dove: 1, olive: 1 };
---
<svg class:list={['botanical', `bot-${kind}`, cls]} viewBox={vb[kind]} fill="none" stroke="currentColor" stroke-width={sw[kind]} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={paths[kind]}></svg>
