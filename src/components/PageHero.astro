---
import { ctas } from '../lib/content';
interface Props { eyebrow: string; title: string; sub?: string; cta?: boolean; }
const { eyebrow, title, sub, cta = true } = Astro.props;
---

<section class="ph">
  <div class="wrap">
    <span class="eyebrow center">{eyebrow}</span>
    <h1 class="serif" set:html={title}></h1>
    {sub && <p class="sub">{sub}</p>}
    {cta && (
      <div class="hero-cta">
        <a class="btn btn-primary" href={ctas.primary.href}>{ctas.primary.label} <span class="arrow">→</span></a>
        <a class="btn btn-ghost" href={ctas.secondary.href}>{ctas.secondary.label}</a>
      </div>
    )}
    <slot />
  </div>
</section>
