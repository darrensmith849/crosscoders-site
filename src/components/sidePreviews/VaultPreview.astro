---
const drops = [
  ['Trading cards', 'Archive rookie set', '$420', 'Verified', 'cards', 'Serial scan matched', '/template-previews/vault-commerce/trading-card-slab.svg'],
  ['Watches', 'Field chronograph', '$1,850', 'Authenticated', 'watches', 'Service history attached', '/template-previews/vault-commerce/watch-dial.svg'],
  ['Art prints', 'Numbered print run', '$690', 'Private drop', 'prints', 'Edition record checked', '/template-previews/vault-commerce/art-print.svg'],
  ['Rare books', 'Signed first issue', '$240', 'Vault held', 'books', 'Signature note reviewed', '/template-previews/vault-commerce/rare-book.svg'],
  ['Design objects', 'Ceramic desk piece', '$520', 'Available', 'objects', 'Condition report filed', '/template-previews/vault-commerce/design-object.svg'],
  ['Studio tools', 'Limited brass ruler', '$110', 'Limited', 'tools', 'Archive label intact', '/template-previews/vault-commerce/studio-tool.svg'],
  ['Event archive items', 'Founders night pass', '$160', 'Verified', 'archive', 'Origin record logged', '/template-previews/vault-commerce/event-pass.svg'],
  ['Signed editions', 'Press room monograph', '$310', 'Available', 'editions', 'Inscription verified', '/template-previews/vault-commerce/signed-edition.svg'],
];

const services = [
  ['Source it', 'Tell the vault what you are hunting for. The request becomes a private sourcing brief.'],
  ['Sell to us', 'Submit an item for review, condition notes and possible acquisition.'],
  ['Authenticate', 'Create confidence around signatures, editions, serials, provenance and condition.'],
  ['Trade', 'Support collector-to-collector movement with proof and clean handover.'],
  ['Vault storage', 'Hold selected items safely until the next drop, sale or private request.'],
];

const culture = [
  ['Issue 014', 'Proof notes', 'How private inventory gets evaluated before release.'],
  ['Issue 015', 'Condition', 'Why grading language should be plain, visible and attached to every item.'],
  ['Issue 016', 'Market', 'What collectors need before they trust a private drop.'],
];
---

<div class="vault-page">
  <nav class="vault-nav" aria-label="Vault Commerce navigation">
    <a href="/template-previews">Vault Commerce</a>
    <div>
      <a href="#vault-drops">Drops</a>
      <a href="#vault-auth">Proof</a>
      <a href="#vault-request">Request hunt</a>
    </div>
  </nav>

  <div class="vault-ticker" aria-hidden="true">
    <span>Private drops / authenticated goods / verified inventory / condition reports / chain of custody / collector services /</span>
    <span>Private drops / authenticated goods / verified inventory / condition reports / chain of custody / collector services /</span>
  </div>

  <section class="vault-hero">
    <div class="vault-copy" data-reveal>
      <p>Authenticated rare goods</p>
      <h1>Rare inventory. Verified before it reaches the shelf.</h1>
      <span>A collector-commerce system for brands that trade in trust, rarity and sharp inventory presentation.</span>
      <div class="vault-actions">
        <a href="#vault-drops">Browse drops</a>
        <a href="#vault-request">Request a hunt</a>
      </div>
    </div>

    <div class="vault-stage" data-reveal>
      <div class="vault-status-lights" aria-label="Vault status">
        <span>Intake online</span>
        <span>Proof locked</span>
        <span>Drop armed</span>
      </div>
      <article class="vault-specimen" aria-label="Featured vault item" data-tilt>
        <div class="vault-specimen-top">
          <span>Vault item / 001</span>
          <b>Verified</b>
        </div>
        <div class="vault-item-art">
          <img src="/template-previews/vault-commerce/trading-card-slab.svg" alt="" />
        </div>
        <h2>Archive rookie set</h2>
        <dl>
          <div><dt>Status</dt><dd>Verified</dd></div>
          <div><dt>Grade</dt><dd>Near mint</dd></div>
          <div><dt>Price</dt><dd>$420</dd></div>
          <div><dt>Proof</dt><dd>Chain of custody attached</dd></div>
        </dl>
      </article>
      <aside class="vault-proof-stack" aria-label="Verification stack">
        <span>01 / Serial scan</span>
        <span>02 / Owner record</span>
        <span>03 / Condition grade</span>
        <span>04 / Release lock</span>
      </aside>
      <aside class="vault-condition">
        <small>Condition report</small>
        <strong>Near mint</strong>
        <p>Edges clean. Surface mark under 2mm. Archive sleeve included.</p>
      </aside>
      <aside class="vault-provenance" aria-label="Provenance path">
        <b>Provenance path</b>
        <ol>
          <li>Original owner logged</li>
          <li>Archive sleeve photographed</li>
          <li>Condition reviewed</li>
          <li>Release approved</li>
        </ol>
      </aside>
    </div>
  </section>

  <section class="vault-trust" aria-label="Trust strip">
    {['Chain of custody', 'Condition report', 'Private sourcing', 'Secure handover', 'Drop alerts'].map((item) => <span data-reveal>{item}</span>)}
  </section>

  <section class="vault-drops" id="vault-drops" data-filter-set>
    <header data-reveal>
      <p>Latest drops</p>
      <h2>Inventory built around rarity and proof.</h2>
    </header>
    <div class="vault-filters" role="group" aria-label="Inventory filters" data-reveal>
      <button type="button" data-filter="all" aria-pressed="true">All</button>
      <button type="button" data-filter="cards" aria-pressed="false">Cards</button>
      <button type="button" data-filter="watches" aria-pressed="false">Watches</button>
      <button type="button" data-filter="prints" aria-pressed="false">Art prints</button>
      <button type="button" data-filter="books" aria-pressed="false">Books</button>
      <button type="button" data-filter="objects" aria-pressed="false">Objects</button>
      <button type="button" data-filter="tools" aria-pressed="false">Tools</button>
    </div>
    <div class="vault-grid">
      {drops.map(([category, name, price, status, filter, proof, asset]) => (
        <article data-filter-item={filter} data-reveal data-tilt>
          <div class="vault-card-art"><img src={asset} alt="" loading="lazy" /></div>
          <span>{status}</span>
          <h3>{name}</h3>
          <p>{category}</p>
          <small>{proof}</small>
          <strong>{price}</strong>
          <a href="#vault-request">Enquire</a>
        </article>
      ))}
    </div>
  </section>

  <section class="vault-feature" data-reveal>
    <div class="vault-feature-art">
      <img src="/template-previews/vault-commerce/signed-edition.svg" alt="" loading="lazy" />
    </div>
    <div>
      <p>Featured specimen</p>
      <h2>Signed edition with documented handover.</h2>
      <span>A premium detail view for high-value pieces: image, condition notes, proof language, provenance timeline and a collector-ready enquiry path.</span>
      <div class="vault-condition-grid" aria-label="Condition table">
        <div><b>Surface</b><span>Clean</span></div>
        <div><b>Edges</b><span>Minor wear</span></div>
        <div><b>Edition</b><span>Numbered</span></div>
        <div><b>Handover</b><span>Documented</span></div>
      </div>
      <ol>
        <li>Intake photos</li>
        <li>Edition check</li>
        <li>Condition notes</li>
        <li>Provenance file</li>
        <li>Release approval</li>
      </ol>
    </div>
  </section>

  <section class="vault-auth" id="vault-auth">
    <header data-reveal>
      <p>Authentication process</p>
      <h2>Proof turns inventory into trust.</h2>
    </header>
    <div class="vault-proof-table" data-reveal>
      <div><b>Serials</b><span>Recorded and matched against item marks.</span></div>
      <div><b>Condition</b><span>Surface, edge, packaging and edition notes captured clearly.</span></div>
      <div><b>Provenance</b><span>Ownership path, purchase context and supporting media attached.</span></div>
      <div><b>Release</b><span>Only approved inventory moves into public or private drops.</span></div>
    </div>
  </section>

  <section class="vault-services">
    <header data-reveal>
      <p>Collector services</p>
      <h2>Beyond the grid.</h2>
    </header>
    <div class="vault-service-grid">
      {services.map(([service, text], index) => (
        <article data-reveal>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{service}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="vault-culture" data-reveal>
    <div>
      <p>Culture log</p>
      <h2>Drops need context, not just stock.</h2>
    </div>
    <div class="vault-culture-grid">
      {culture.map(([issue, tag, title]) => (
        <article>
          <span>{issue}</span>
          <small>{tag}</small>
          <h3>{title}</h3>
          <p>Short-form editorial context for collectors who want to understand the proof behind a drop.</p>
        </article>
      ))}
    </div>
  </section>

  <section class="vault-request" id="vault-request" data-reveal>
    <div>
      <p>Private request</p>
      <h2>Looking for something specific?</h2>
      <span>Capture collector intent before the item exists in inventory and convert it into a sourcing brief.</span>
    </div>
    <form onsubmit="return false" aria-label="Request a hunt">
      <label>Email<input type="email" name="email" /></label>
      <label>Target item<input type="text" name="target" /></label>
      <label>Category<select name="category"><option>Trading cards</option><option>Watches</option><option>Art prints</option><option>Rare books</option><option>Design objects</option><option>Studio tools</option><option>Event archive items</option><option>Signed editions</option></select></label>
      <label>Budget range<input type="text" name="budget" /></label>
      <label>Condition preference<select name="condition"><option>Verified only</option><option>Near mint or better</option><option>Open to graded wear</option></select></label>
      <label>Timeline<select name="timeline"><option>Ready now</option><option>Within 30 days</option><option>Long-term hunt</option></select></label>
      <label class="vault-notes">Notes<textarea name="notes" rows="4"></textarea></label>
      <button type="submit">Request hunt</button>
    </form>
  </section>

  <section class="vault-alerts" data-reveal>
    <span>Drop alerts</span>
    <strong>Get notified before inventory opens publicly.</strong>
    <form onsubmit="return false" aria-label="Join drop alerts">
      <label>Email<input type="email" name="alert-email" /></label>
      <button type="submit">Join list</button>
    </form>
  </section>

  <footer class="vault-footer">
    <a href="/template-previews">Back to side preview gallery</a>
    <span>View-only preview / not connected to the engine</span>
  </footer>
</div>
