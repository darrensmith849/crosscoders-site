---
const stats = [
  ['Recognition', 'Selected client work'],
  ['Focus', 'Strategy / Design / Advisory'],
  ['Engagement', 'Senior-led from first call'],
  ['Method', 'Diagnosis before delivery'],
];

const principles = [
  ['Clarity first', 'Every engagement begins by turning complexity into a decision-ready frame.'],
  ['Evidence over theatre', 'Recommendations are grounded in interviews, artefacts, constraints and operating reality.'],
  ['Taste in delivery', 'Implementation is shaped with judgement, restraint and care for the people who inherit the work.'],
];

const services = [
  ['Strategy', 'Positioning, discovery, product framing and decision support.'],
  ['Design', 'Identity, digital systems, spaces, service design and communication.'],
  ['Advisory', 'Senior guidance for teams navigating high-stakes change.'],
  ['Delivery', 'Implementation support, documentation, supplier coordination and launch.'],
  ['Audit', 'A clear assessment of what works, what is weak and what should change.'],
  ['Support', 'Ongoing retainers, workshops and practical improvement cycles.'],
];

const cases = [
  ['01', 'Northline advisory system', 'Strategy / Delivery', 'Sharper operating model'],
  ['02', 'Atelier operating manual', 'Design / Support', 'Clearer studio rituals'],
  ['03', 'Civic service review', 'Audit / Advisory', 'Practical next-step roadmap'],
  ['04', 'Independent practice launch', 'Identity / Digital', 'Stronger trust signal'],
];

const journal = [
  ['How to frame a complex brief', 'A short note on turning unclear requirements into a decision-ready project frame.'],
  ['What a good audit actually includes', 'A practical look at evidence, gaps, risk and the next useful action.'],
  ['Why delivery needs taste', 'Why implementation is not just execution, but judgement under constraint.'],
];
---

<div class="editorial-page">
  <nav class="editorial-nav" aria-label="Editorial Practice navigation">
    <a href="/template-previews">Editorial Practice</a>
    <div>
      <a href="#editorial-services">Services</a>
      <a href="#editorial-cases">Cases</a>
      <a href="#editorial-consult">Consultation</a>
    </div>
  </nav>

  <section class="editorial-hero">
    <div class="editorial-copy" data-reveal>
      <p>Independent practice</p>
      <h1>Clear thinking, carefully delivered.</h1>
      <span>A premium preview for expert-led practices that need trust, taste and a portfolio of work.</span>
      <div class="editorial-actions">
        <a href="#editorial-consult">Start a project</a>
        <a href="#editorial-services">View services</a>
      </div>
    </div>
    <article class="editorial-featured" data-reveal>
      <p>Featured project</p>
      <h2>Northline advisory system</h2>
      <dl>
        <div><dt>Category</dt><dd>Strategy / Delivery</dd></div>
        <div><dt>Year</dt><dd>2026</dd></div>
        <div><dt>Outcome</dt><dd>Sharper operating model</dd></div>
      </dl>
    </article>
  </section>

  <section class="editorial-stat-row" aria-label="Practice credibility">
    {stats.map(([label, value]) => <p data-reveal><span>{label}</span><strong>{value}</strong></p>)}
  </section>

  <section class="editorial-philosophy">
    <div data-reveal>
      <p>Philosophy</p>
      <h2>Expert work should feel calm, legible and deeply considered.</h2>
    </div>
    <article data-reveal>
      <p>This preview is built for firms that do not need noise to prove value: just a clear point of view, visible method, sharp case summaries and a serious consultation path.</p>
    </article>
  </section>

  <section class="editorial-principles" aria-label="Practice principles">
    {principles.map(([title, text], index) => (
      <article data-reveal>
        <span>{String(index + 1).padStart(2, '0')}</span>
        <h3>{title}</h3>
        <p>{text}</p>
      </article>
    ))}
  </section>

  <section class="editorial-services" id="editorial-services">
    <header data-reveal>
      <p>Services</p>
      <h2>Six ways the practice can help.</h2>
    </header>
    <div class="editorial-service-list">
      {services.map(([title, text], index) => (
        <details data-reveal open={index === 0}>
          <summary>{title}</summary>
          <p>{text}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="editorial-cases" id="editorial-cases">
    <header data-reveal>
      <p>Case studies</p>
      <h2>Selected work index.</h2>
    </header>
    <div class="editorial-case-index">
      {cases.map(([number, name, category, outcome]) => (
        <article data-reveal>
          <span>{number}</span>
          <h3>{name}</h3>
          <p>{category}</p>
          <strong>{outcome}</strong>
          <a href="#editorial-consult">Discuss similar work</a>
        </article>
      ))}
    </div>
  </section>

  <section class="editorial-profile" data-reveal>
    <blockquote>
      <p>"The strongest professional sites do not shout. They clarify why the practice should be trusted."</p>
      <cite>Founder profile panel</cite>
    </blockquote>
    <aside>
      <span>Profile</span>
      <h2>Senior judgement, visible process.</h2>
      <p>Use this panel for a founder note, partner profile or practice story that makes expertise feel human and accountable.</p>
    </aside>
  </section>

  <section class="editorial-journal">
    <header data-reveal>
      <p>Journal</p>
      <h2>Insights that prove how the team thinks.</h2>
    </header>
    <div class="editorial-journal-list">
      {journal.map(([title, text]) => (
        <article data-reveal>
          <span>Insight</span>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="editorial-consult" id="editorial-consult" data-reveal>
    <div>
      <p>Consultation</p>
      <h2>Start with a clear first conversation.</h2>
      <span>Use this form for project fit, intake quality and next-step scheduling without making the page feel sales-heavy.</span>
    </div>
    <form onsubmit="return false" aria-label="Request consultation">
      <label>Name<input type="text" name="name" /></label>
      <label>Email<input type="email" name="email" /></label>
      <label>Project type<input type="text" name="project-type" /></label>
      <button type="submit">Request consultation</button>
    </form>
  </section>

  <footer class="editorial-footer">
    <a href="/template-previews">Back to side preview gallery</a>
    <span>View-only preview / not connected to the engine</span>
  </footer>
</div>
