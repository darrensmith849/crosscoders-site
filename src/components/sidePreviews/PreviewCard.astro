---
interface SidePreview {
  slug: string;
  name: string;
  tag: string;
  bestFor: string;
  description: string;
  className: string;
}

const { preview } = Astro.props as { preview: SidePreview };
---

<a class={`sp-card ${preview.className}`} href={`/template-previews/${preview.slug}`} data-reveal>
  <div class="sp-card-visual" aria-hidden="true">
    <span></span><span></span><span></span><span></span>
  </div>
  <div class="sp-card-copy">
    <p>{preview.tag}</p>
    <h2>{preview.name}</h2>
    <strong>Best for: {preview.bestFor}</strong>
    <span>{preview.description}</span>
  </div>
</a>
