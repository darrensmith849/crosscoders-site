---
const metadata = [
  ['Status', 'Registering interest'],
  ['Location', 'Northline district'],
  ['Completion', 'Future release'],
  ['Spaces', 'Studio / Suite / Office'],
];

const travel = [
  ['Station', '4 min walk'],
  ['Airport', '22 min drive'],
  ['Waterfront', '9 min cycle'],
  ['Cultural quarter', '6 min walk'],
];

const spaces = [
  ['office', 'Office', '120-420 m2', 'Floors 4-8', 'Available'],
  ['residence', 'Residence', '74-160 m2', 'Levels 9-14', 'Waitlist'],
  ['suite', 'Suite', '45-90 m2', 'Garden edge', 'Available'],
  ['studio', 'Studio', '38-60 m2', 'Lower court', 'Limited'],
];
---

<div class="spatial-page">
  <nav class="spatial-nav" aria-label="Spatial Rise navigation">
    <a href="/template-previews">Spatial Rise</a>
    <div>
      <a href="#spatial-arrival">Story</a>
      <a href="#spatial-spaces">Spaces</a>
      <button type="button" data-open-drawer="#spatialDrawer">Request information</button>
    </div>
  </nav>

  <section class="spatial-hero">
    <div class="spatial-hero-image" data-reveal aria-hidden="true"><span></span><span></span><span></span></div>
    <div class="spatial-hero-copy" data-reveal>
      <p>A place designed to be felt</p>
      <h1>Architecture for the next chapter.</h1>
      <span>A spatial preview for developments, venues and destinations that need atmosphere, confidence and enquiry conversion.</span>
      <div class="spatial-actions">
        <a href="#spatial-arrival">Explore the project</a>
        <button type="button" data-open-drawer="#spatialDrawer">Request information</button>
      </div>
    </div>
    <aside class="spatial-meta" aria-label="Project metadata" data-reveal>
      {metadata.map(([label, value]) => <p><span>{label}</span><strong>{value}</strong></p>)}
    </aside>
    <a class="spatial-scroll" href="#spatial-arrival">Scroll / chapters</a>
  </section>

  <section class="spatial-strip" aria-label="Project metadata strip">
    {metadata.map(([label, value]) => (
      <div data-reveal><span>{label}</span><strong>{value}</strong></div>
    ))}
  </section>

  <section class="spatial-chapter spatial-arrival" id="spatial-arrival">
    <div class="spatial-chapter-media" data-reveal aria-hidden="true"></div>
    <article data-reveal>
      <p>Chapter 01 / Arrival</p>
      <h2>The first impression is quiet, grounded and deliberate.</h2>
      <span>The page opens like a place rather than a pitch: large atmosphere, measured copy and clear project details that help visitors understand the offer before they enquire.</span>
    </article>
  </section>

  <section class="spatial-chapter spatial-material">
    <article data-reveal>
      <p>Chapter 02 / Architecture</p>
      <h2>Materiality carries the story from exterior to interior.</h2>
      <span>Use this sequence for facade logic, garden courts, hospitality moments, finishes, sustainability notes and spatial decisions that build confidence.</span>
    </article>
    <div class="spatial-chapter-media warm" data-reveal aria-hidden="true"></div>
  </section>

  <section class="spatial-experience">
    <header data-reveal>
      <p>Chapter 03 / Experience</p>
      <h2>Amenities designed around daily rhythm.</h2>
    </header>
    <div class="spatial-experience-grid">
      <article data-reveal><span>01</span><h3>Garden arrival</h3><p>A calm threshold between street, lobby and inner court.</p></article>
      <article data-reveal><span>02</span><h3>Shared terrace</h3><p>An elevated gathering edge for work, hospitality and evening light.</p></article>
      <article data-reveal><span>03</span><h3>Ground floor life</h3><p>Retail, studio and welcome spaces keep the project active at street level.</p></article>
    </div>
  </section>

  <section class="spatial-location">
    <div class="spatial-map" data-reveal aria-label="Illustrative location map">
      <i></i><i></i><i></i><b>Northline / civic edge</b>
    </div>
    <div class="spatial-travel" data-reveal>
      <p>Location</p>
      <h2>Connected to the daily map.</h2>
      {travel.map(([place, time]) => <div><strong>{time}</strong><span>{place}</span></div>)}
    </div>
  </section>

  <section class="spatial-spaces" id="spatial-spaces" data-filter-set>
    <header data-reveal>
      <p>Spaces selector</p>
      <h2>Let visitors compare the right space without turning the page into a brochure dump.</h2>
    </header>
    <div class="spatial-filters" role="group" aria-label="Space filters" data-reveal>
      <button type="button" data-filter="all" aria-pressed="true">All</button>
      <button type="button" data-filter="office" aria-pressed="false">Office</button>
      <button type="button" data-filter="residence" aria-pressed="false">Residence</button>
      <button type="button" data-filter="suite" aria-pressed="false">Suite</button>
      <button type="button" data-filter="studio" aria-pressed="false">Studio</button>
    </div>
    <div class="spatial-space-list">
      {spaces.map(([type, name, size, floor, status]) => (
        <article data-filter-item={type} data-reveal>
          <span>{status}</span>
          <h3>{name}</h3>
          <p>{size}</p>
          <p>{floor}</p>
          <button type="button" data-open-drawer="#spatialDrawer">Enquire</button>
        </article>
      ))}
    </div>
  </section>

  <section class="spatial-gallery" aria-label="Spatial gallery">
    {['Lobby arrival', 'Garden court', 'Evening terrace', 'Material study'].map((item, index) => (
      <button type="button" class={`spatial-gallery-item tone-${index + 1}`} data-lightbox-source data-title={item} data-tone={`tone-${index + 1}`} data-reveal>
        <span>{item}</span>
      </button>
    ))}
  </section>

  <section class="spatial-info" data-reveal>
    <h2>Request the information pack.</h2>
    <p>Use this CTA for brochures, venue tours, registration forms or private project enquiries.</p>
    <button type="button" data-open-drawer="#spatialDrawer">Request information</button>
  </section>

  <div class="sp-drawer" id="spatialDrawer" aria-hidden="true" role="dialog" aria-label="Request information">
    <div>
      <button class="sp-close" type="button" data-close-drawer>Close</button>
      <h2>Request information</h2>
      <p>Share the space type and contact details, then route the enquiry to sales, leasing or hospitality.</p>
      <form onsubmit="return false">
        <label>Name<input type="text" name="name" /></label>
        <label>Email<input type="email" name="email" /></label>
        <label>Interest<select name="interest"><option>Office</option><option>Residence</option><option>Suite</option><option>Studio</option></select></label>
        <button type="submit">Send enquiry</button>
      </form>
    </div>
  </div>

  <div class="sp-lightbox" id="sidePreviewLightbox" aria-hidden="true" role="dialog" aria-label="Gallery preview">
    <button class="sp-close" type="button" data-close-drawer>Close</button>
    <div class="lightbox-image" data-lightbox-image></div>
    <h2 data-lightbox-title>Gallery view</h2>
  </div>

  <footer class="spatial-footer">
    <a href="/template-previews">Back to side preview gallery</a>
    <span>View-only preview / not connected to the engine</span>
  </footer>
</div>
