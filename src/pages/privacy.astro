---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { brand } from '../lib/content';
---

<BaseLayout title="Privacy policy | CrossCoders" description="How CrossCoders collects, uses and protects your data.">
  <PageHero eyebrow="Legal" title="Privacy policy." cta={false} />
  <section class="psec">
    <div class="wrap prose">
      <p style="color:var(--ink-mute)">Last updated: 2026. This summary is provided for transparency; the final policy and our registered entity details are being confirmed with legal counsel.</p>
      <h2 class="serif">Who we are</h2>
      <p>CrossCoders is a Christian software studio, operating a commercial studio and a non-profit Foundation. You can reach us at <a href={brand.contactHref} style="color:var(--forest-deep)">{brand.email}</a>.</p>
      <h2 class="serif">What we collect</h2>
      <p>Information you give us through our forms (such as your name, email, phone, organisation and message), and privacy-friendly, cookieless analytics about how the site is used. We do not track you across the web.</p>
      <h2 class="serif">How we use it</h2>
      <p>To respond to your enquiry, provide our services, and improve the site. We don’t sell your data, and we don’t use it to train AI models.</p>
      <h2 class="serif">Who we share it with</h2>
      <p>Only the service providers we use to run the site and respond to you (such as our hosting, email and scheduling tools), under appropriate agreements.</p>
      <h2 class="serif">Your rights</h2>
      <p>You can ask us to access, correct or delete your information at any time. We aim to comply with applicable data-protection law, including GDPR and POPIA. Contact us at <a href={brand.contactHref} style="color:var(--forest-deep)">{brand.email}</a>.</p>
    </div>
  </section>
</BaseLayout>
