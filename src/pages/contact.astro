---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Faq from '../components/Faq.astro';
import { brand } from '../lib/content';
import { faqCategories } from '../lib/pages';
import PhotoBand from '../components/demos/PhotoBand.astro';

const expect = ['We read every message', 'We reply by email, fast', 'Honest advice — no hard sell', 'A clear next step, no obligation'];
const faq = faqCategories.find((c) => c.category === 'Working with us')!.items;
---

<BaseLayout title="Contact CrossCoders" description="Tell us what you need — an app, a site, an agent, or 'not sure yet'. We'll read it and reply by email — no pressure.">
  <PageHero eyebrow="Get in touch" title="Let's talk." sub="Tell us what you need — an app, a site, an agent, or 'not sure yet'. We'll read it and reply by email." cta={false} />

  <section class="psec">
    <div class="wrap formwrap">
      <form data-contactform novalidate>
        <input type="text" name="hp_check" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px" aria-hidden="true" data-1p-ignore data-lpignore="true" data-form-type="other" />
        <div class="field"><label>Your name *</label><input name="name" required /></div>
        <div class="field"><label>Organisation</label><input name="org" /></div>
        <div class="field"><label>Email *</label><input name="email" type="email" required /></div>
        <div class="field"><label>Phone / WhatsApp</label><input name="phone" /></div>
        <div class="field"><label>What do you need?</label><select name="need"><option>Not sure yet</option><option>App or custom software</option><option>Website</option><option>AI agent</option><option>Chatbot</option><option>Automation</option></select></div>
        <div class="field"><label>Tell us about your project *</label><textarea name="message" required></textarea></div>
        <button class="btn btn-primary" type="submit">Send message <span class="arrow">→</span></button>
        <p style="font-size:.85rem;color:var(--ink-mute);margin-top:14px">Prefer email? <a href={brand.contactHref} style="color:var(--forest-deep)">Get in touch</a></p>
      </form>
      <aside class="sidecard">
        <h4>What to expect</h4>
        {expect.map((s, i) => (
          <div class="sidestep"><span class="n">{i + 1}</span><p>{s}</p></div>
        ))}
        <p style="font-size:.85rem;color:var(--ink-mute);margin-top:8px;line-height:1.5">Under-resourced church or ministry? You may qualify for a <a href="/foundation/apply" style="color:var(--forest-deep)">free build →</a></p>
      </aside>
    </div>
  </section>

  <section class="psec" style="background:var(--paper);border-top:1px solid var(--line)">
    <div class="wrap">
      <span class="eyebrow">Before you ask</span>
      <Faq items={faq} />
    </div>
  </section>

  <PhotoBand
    img="/img/ws-07.jpg"
    alt="A friendly, relaxed workspace where a conversation is about to happen"
    eyebrow="What to expect"
    title="There's a real person on the other end."
    body="No bots, no call-centre script — a real person reads every message and replies honestly. Want a free build? The fastest route is to apply through the Foundation."
    c1={{ t: 'A real person', s: 'reads every message' }}
    c2={{ t: 'We reply', s: 'by email, fast' }}
    c3={{ big: '0', s: 'pressure', up: 'promise' }}
  />

  <script>
    import { api } from '../lib/api';
    const f = document.querySelector('[data-contactform]');
    if (f) {
      f.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = f.querySelector('button[type=submit]');
        const data = Object.fromEntries(new FormData(f).entries());
        data.source = 'Contact form';
        const orig = btn.innerHTML; btn.disabled = true; btn.textContent = 'Sending…';
        try {
          const r = await fetch(api('/api/contact'), { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(data) });
          const j = await r.json().catch(() => ({}));
          if (!r.ok || !j.ok) throw new Error();
          f.innerHTML = '<div class="apply-done"><h3 class="serif">Thank you — we\'ve got it.</h3><p>A real person reads every message and will reply by email. No bots, no pressure.</p></div>';
        } catch {
          btn.disabled = false; btn.innerHTML = orig;
          let m = f.querySelector('.apply-err');
          if (!m) { m = document.createElement('p'); m.className = 'apply-err'; btn.insertAdjacentElement('afterend', m); }
          m.textContent = 'Sorry — something went wrong. Please email daniel@crosscoders.co.za and we\'ll sort it out.';
        }
      });
    }
  </script>
</BaseLayout>
