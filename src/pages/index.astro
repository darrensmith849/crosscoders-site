---
import BaseLayout from '../layouts/BaseLayout.astro';
import LiveBuild from '../components/demos/LiveBuild.astro';
import PhotoBand from '../components/demos/PhotoBand.astro';
import PhoneDuo from '../components/demos/PhoneDuo.astro';
import Dashboard from '../components/demos/Dashboard.astro';
import AgentChat from '../components/demos/AgentChat.astro';
import ReliefBand from '../components/ReliefBand.astro';
import { ctas, products } from '../lib/content';

const icons: Record<string, string> = {
  app: '<svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18M8 21h8"/></svg>',
  web: '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>',
  agent: '<svg viewBox="0 0 24 24"><rect x="4" y="7" width="16" height="12" rx="3"/><path d="M12 7V4M9 13h.01M15 13h.01"/></svg>',
  chat: '<svg viewBox="0 0 24 24"><path d="M21 12a8 8 0 0 1-11.5 7.2L4 20l1-4.5A8 8 0 1 1 21 12z"/></svg>',
  auto: '<svg viewBox="0 0 24 24"><path d="M4 7h10a4 4 0 0 1 0 8H8a4 4 0 0 0 0 8"/><circle cx="18" cy="7" r="2.4"/><circle cx="6" cy="19" r="2.4"/></svg>',
  code: '<svg viewBox="0 0 24 24"><path d="M8 9l-4 3 4 3M16 9l4 3-4 3M13 6l-2 12"/></svg>',
};

const logos: [string, string][] = [
  ['<svg viewBox="0 0 24 24"><path d="M5 20V10l7-5 7 5v10"/><path d="M9 20v-5h6v5"/><path d="M12 2.5v3M10.5 4h3"/></svg>', 'Grace Chapel'],
  ['<svg viewBox="0 0 24 24"><circle cx="7.5" cy="9.5" r="2.3"/><circle cx="16.5" cy="9.5" r="2.3"/><circle cx="12" cy="15" r="2.3"/></svg>', 'Hope Community'],
  ['<svg viewBox="0 0 24 24"><path d="M12 3l8 4.5v9L12 21l-8-4.5v-9z"/><path d="M4 7.5l8 4.5 8-4.5M12 12v9"/></svg>', 'Cornerstone'],
  ['<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8.5"/><path d="M12 7v10M9 11h6"/></svg>', 'Redeemer Network'],
  ['<svg viewBox="0 0 24 24"><path d="M3 17a9 9 0 0 1 18 0"/><path d="M3 17v3M21 17v3M9 17v3M15 17v3M12 8.5v8.5"/></svg>', 'The Bridge'],
  ['<svg viewBox="0 0 24 24"><path d="M12 21v-8"/><path d="M12 13c-.6-3-3-4.6-6-4 0 3 2.4 4.6 6 4z"/><path d="M12 15c.6-3.4 3-5 6.5-4.4 0 3.4-3 5-6.5 4.4z"/></svg>', 'New Life'],
  ['<svg viewBox="0 0 24 24"><circle cx="12" cy="4.5" r="2"/><path d="M12 6.5v14"/><path d="M5 13a7 7 0 0 0 14 0"/><path d="M4.5 13H8M16 13h3.5"/></svg>', 'Anchor City'],
  ['<svg viewBox="0 0 24 24"><path d="M9 21h6"/><path d="M10.5 12h3l.8 9h-4.6z"/><path d="M11 7.5h2l.5 4.5h-3z"/><path d="M12 4.5V6"/><path d="M8 8L6 7M16 8l2-1"/></svg>', 'Lighthouse'],
];
const loop = [...logos, ...logos];

const appsProduct = products.find((p) => p.slug === 'web-mobile-apps');
---

<BaseLayout>
  <section class="hero">
    <div class="aurora"><span class="blob a"></span><span class="blob b"></span><span class="blob c"></span></div>
    <div class="wrap">
      <div class="hero-grid">
        <div>
          <span class="eyebrow">A Christian software nonprofit</span>
          <h1 class="serif">Free, quality software, <em class="us-forest">given</em> to the church.</h1>
          <p class="sub">CrossCoders is a Christian nonprofit. We design and build apps, websites and AI — then give them, free, to under-resourced churches and Christian organisations. Funded by supporters and paid work, multiplied by AI.</p>
          <div class="hero-cta">
            <a class="btn btn-primary magnetic" href={ctas.fund.href}>{ctas.fund.label} <span class="arrow">→</span></a>
            <a class="btn btn-ghost" href={ctas.primary.href}>{ctas.primary.label} <span class="arrow">→</span></a>
          </div>
          <div class="trust"><span>Built with Claude</span><span>Shipped in days, not months</span><span>Free for churches</span></div>
        </div>
        <LiveBuild />
      </div>
    </div>
    <div class="marq">
      <div class="marq-track">
        {loop.map(([svg, name]) => (
          <div class="lg"><Fragment set:html={svg} /><span>{name}</span></div>
        ))}
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="sec-head center rev">
        <span class="eyebrow center">What we build</span>
        <h2 class="serif">If it can be built, we build it — beautifully.</h2>
        <p>One senior team, the full stack of what a modern mission needs online.</p>
      </div>
      <div class="grid3">
        {products.map((p) => (
          <a class="card tilt rev" href={`/services/${p.slug}`}>
            <div class="ic"><Fragment set:html={icons[p.icon]} /></div>
            <h3 class="serif">{p.name}</h3>
            <p>{p.blurb}</p>
            <span class="card-more">Learn more <span class="arrow">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <ReliefBand
    eyebrow="Why we exist"
    title={"The people doing the most important work <span class='hl'>shouldn't have the worst tools.</span>"}
    body="So we build world-class software and give it away — funded by supporters and paid work, multiplied by AI."
  />

  <PhotoBand />

  <section class="sec">
    <div class="wrap">
      <div class="sec-head center rev">
        <span class="eyebrow center">Web · iOS · Android</span>
        <h2 class="serif">One build. Every screen.</h2>
        <p>The same product, beautifully native everywhere — including the app that lives in their pocket.</p>
      </div>
      <PhoneDuo />
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="work">
        <div class="rev">
          <span class="eyebrow">Web apps &amp; dashboards</span>
          <h2 class="serif" style="font-size:clamp(1.9rem,3.6vw,2.8rem);line-height:1.1;margin-top:16px">Know your people. One screen, the whole picture.</h2>
          <p style="color:var(--ink-soft);margin-top:16px;font-size:1.05rem">Member portals, giving analytics and admin tools — the dashboards your team actually logs into, built around how you work and updating live.</p>
          <a class="btn btn-ghost" href={`/services/${appsProduct?.slug ?? 'web-mobile-apps'}`} style="margin-top:20px">Explore web apps <span class="arrow">→</span></a>
        </div>
        <Dashboard />
      </div>
    </div>
  </section>

  <section class="sec dark">
    <div class="wrap">
      <div class="craft">
        <div class="rev">
          <span class="eyebrow">Senior craft, multiplied by AI</span>
          <h2 class="serif">We build like it matters — because it does.</h2>
          <p>We pair years of real engineering with the best AI tools to ship more, faster, and to a higher standard than a team our size should be able to. It's how we deliver enterprise-quality work without the enterprise price — and how we give so much of it away.</p>
          <div class="stats">
            <div class="stat"><div class="n">10×</div><div class="l">faster delivery</div></div>
            <div class="stat"><div class="n">24/7</div><div class="l">agents that never sleep</div></div>
            <div class="stat"><div class="n">∞</div><div class="l">care after launch</div></div>
          </div>
        </div>
        <div class="rev"><AgentChat /></div>
      </div>
    </div>
  </section>

  <section class="sec mission">
    <div class="wrap">
      <span class="eyebrow center rev">The CrossCoders Foundation</span>
      <div class="big rev">Every church deserves a home online — <span class="us-brass">not just</span> the ones who can afford it.</div>
      <p class="body rev">Great technology shouldn't be a luxury. By pairing our skills with AI, we deliver exceptional work at a fraction of the usual cost — and give a huge amount of it away. Every paid project helps fund the next free build for an under-resourced church or ministry.</p>
      <a class="btn btn-ghost lk rev" href="/foundation">Apply for a free build <span class="arrow">→</span></a>
    </div>
  </section>

  <section class="quote">
    <div class="wrap">
      <span class="eyebrow center rev">What we believe</span>
      <blockquote class="rev">“Excellent work is a form of worship. So we build everything — paid or free, large or small — like it's being seen by Someone who notices.”</blockquote>
      <div class="by rev">— The CrossCoders team</div>
    </div>
  </section>

  <section class="sec cta oak">
    <div class="wrap">
      <h2 class="serif">Let's build something that matters.</h2>
      <p>Tell us what you need — an app, a site, an agent, or all three. No pressure, no hard sell.</p>
      <div class="hero-cta">
        <a class="btn btn-primary magnetic" href={ctas.primary.href}>{ctas.primary.label} <span class="arrow">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .grid3 .card { display: flex; flex-direction: column; }
  .card-more { margin-top: auto; padding-top: 18px; align-self: flex-start; display: inline-flex; align-items: center; gap: 6px; font-size: .85rem; font-weight: 600; color: var(--forest-deep); }
  .card-more .arrow { transition: transform .2s ease; }
  .card:hover .card-more { color: var(--forest); }
  .card:hover .card-more .arrow { transform: translateX(4px); }
</style>
