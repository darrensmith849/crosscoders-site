---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found | CrossCoders" description="That page wandered off.">
  <section class="ph" style="padding:120px 0 100px">
    <div class="wrap">
      <span class="eyebrow center">404</span>
      <h1 class="serif">This page wandered off.</h1>
      <p class="sub">Let's get you back to something that matters.</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="/">Back home <span class="arrow">→</span></a>
        <a class="btn btn-ghost" href="/services">What we build</a>
      </div>
    </div>
  </section>
</BaseLayout>
