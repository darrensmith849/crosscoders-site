---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import FinalCta from '../components/FinalCta.astro';
import PhotoCluster from '../components/demos/PhotoCluster.astro';
import PhotoFigure from '../components/demos/PhotoFigure.astro';

const values = [
  { t: 'Excellence as worship', d: 'We build everything — paid or free, large or small — like it’s being seen by Someone who notices.' },
  { t: 'Service', d: 'We care about your mission as much as your software. Your win is the point.' },
  { t: 'Integrity', d: 'Honest advice, honest timelines, honest pricing. Even when it costs us.' },
  { t: 'Craft', d: 'Custom, considered, and built to last — never a template with your name on it.' },
];
const slug = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const team: { name: string; full?: string; role: string; bio: string; photo?: string; about?: string }[] = [
  {
    name: 'Daniel', full: 'Daniel Jenkins', role: 'Founder · Engineering & AI', photo: '/img/daniel.jpg',
    bio: 'Founded Kingdom Come Foundation — the umbrella over CrossCoders — and leads the build: apps, agents and the AI that lets a small team do extraordinary work.',
    about: 'Before the code, there was music. For a decade Daniel toured the world as a musician — opening for Prime Circle, playing cruise ships from Antarctica onward, and sharing stages across Zimbabwe with Ammara Brown and Jah Prayzah. It looked glamorous from the outside and felt isolating from the inside. A near-death experience and a return to faith changed everything — less of him, more of God. That same conviction now drives the build: he founded Kingdom Come Foundation, the umbrella over CrossCoders, pairing senior engineering with AI so the Church gets world-class tools, free.',
  },
];
---

<BaseLayout
  title="About CrossCoders — a Christian software studio | Christ, code & coffee"
  description="Meet the small senior team behind CrossCoders — why we build, what we believe, and how excellent work becomes worship."
>
  <PageHero
    eyebrow="Christ, code & coffee"
    title="A small team, building like it matters."
    sub="Senior people, big leverage, and a real mission — software worth believing in."
  />

  <section class="psec">
    <div class="wrap two">
      <div>
        <span class="eyebrow">Our story</span>
        <h2 class="serif" style="margin:16px 0 16px;font-size:clamp(1.9rem,3.4vw,2.5rem)">Built by people who care about the mission.</h2>
        <p style="color:var(--ink-soft);line-height:1.75;font-size:1.08rem">CrossCoders started with a simple conviction: the people doing the most important work often have the worst tools. Churches, ministries and mission-driven teams deserve world-class software — not clip-art templates and clunky systems. So we build it, pair it with AI to make it affordable, and give as much of it away as we can.</p>
      </div>
      <PhotoCluster
        imgA="/img/ws-01.jpg"
        altA="A sunlit studio desk with plants, wood and a screen mid-build"
        imgB="/img/ws-09.jpg"
        altB="A diverse team working together over laptops and coffee"
        card={{ big: 'R18,420', s: 'given this month', up: '▲ 12%' }}
      />
    </div>
  </section>

  <section class="psec dark">
    <div class="wrap">
      <span class="eyebrow">What we believe</span>
      <h2 class="serif" style="margin:16px 0 30px;font-size:clamp(1.9rem,3.6vw,2.6rem)">Why we build the way we do.</h2>
      <div class="grid3">
        {values.map((v) => (
          <div class="card" style="background:var(--mocha);border-color:var(--dline)"><h3 class="serif" style="color:var(--cream-d)">{v.t}</h3><p style="color:var(--cream-muted)">{v.d}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="psec" style="background:var(--paper);border-top:1px solid var(--line);border-bottom:1px solid var(--line)">
    <div class="wrap">
      <span class="eyebrow">Founder</span>
      <h2 class="serif" style="margin:16px 0 30px;font-size:clamp(1.9rem,3.6vw,2.6rem)">Meet the founder.</h2>
      <div class="team">
        {team.map((m) => (
          <div class={m.photo ? 'tcard founder' : 'tcard'}>
            {m.photo
              ? <button class="founder-photo" type="button" style={`background-image:url(${m.photo})`} data-bio={slug(m.name)} aria-label={`Read about ${m.name}`}></button>
              : <div class="av"></div>}
            <div class="founder-body">
              <h4>{m.name}</h4>
              <div class="role">{m.role}</div>
              <p>{m.bio}</p>
              {m.about && <button class="tcard-more" type="button" data-bio={slug(m.name)}>Read about {m.name} <span class="arrow">→</span></button>}
            </div>
          </div>
        ))}
      </div>
      {team.filter((m) => m.about).map((m) => (
        <div class="bio-modal" id={`bio-${slug(m.name)}`} hidden>
          <div class="bio-backdrop" data-close></div>
          <div class="bio-panel" style={`background-image:url(${m.photo})`}>
            <button class="bio-close" type="button" data-close aria-label="Close">✕</button>
            <div class="bio-scrim"></div>
            <div class="bio-content">
              <div class="bio-name serif">{m.full ?? m.name}</div>
              <div class="bio-role">{m.role}</div>
              <p>{m.about}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="psec">
    <div class="wrap two">
      <PhotoFigure
        img="/img/ws-06.jpg"
        alt="The team and friends talking over coffee in a bright, plant-filled space"
        portrait={true}
        pos="br"
        card={{ kind: 'status', t: 'Over coffee', s: 'where the best work starts' }}
      />
      <div>
        <span class="eyebrow">Christ, code &amp; coffee</span>
        <h2 class="serif" style="margin:16px 0 16px;font-size:clamp(1.9rem,3.4vw,2.5rem)">We build it like it matters — because it does.</h2>
        <p style="color:var(--ink-soft);line-height:1.75;font-size:1.08rem">No junior hand-offs, no template factory. Just senior people who care about your mission, building carefully, and treating excellent work as a form of worship.</p>
      </div>
    </div>
  </section>

  <section class="psec" style="background:var(--paper);border-top:1px solid var(--line)">
    <div class="wrap" style="max-width:720px">
      <span class="eyebrow">The Foundation</span>
      <p class="lead" style="margin-top:18px;font-size:1.22rem">We believe every church deserves a home online — not just the ones who can afford it. Our paid work funds free builds for those who can’t. <a href="/foundation" style="color:var(--forest-deep);text-decoration:underline">Explore the Foundation →</a></p>
    </div>
  </section>

  <FinalCta />
</BaseLayout>

<style>
  .team { grid-template-columns: minmax(0, 420px); justify-content: center; }
  .team .tcard.founder { padding: 0; overflow: hidden; text-align: center; }
  .founder-photo { display: block; width: 100%; aspect-ratio: 4 / 5; margin: 0; padding: 0; border: 0; cursor: pointer; background-size: cover; background-position: 50% 18%; transition: transform .45s ease; }
  .founder-photo:hover { transform: scale(1.04); }
  .founder-body { padding: 24px 28px 30px; }
  .founder-body h4 { font-size: 1.45rem; margin: 0 0 6px; }
  .founder-body .role { font-size: .86rem; }
  .founder-body p { font-size: .95rem; margin-top: 8px; }
  .tcard-more { display: inline-flex; align-items: center; gap: 6px; margin-top: 14px; background: none; border: 0; cursor: pointer; font: inherit; font-size: .85rem; font-weight: 600; color: var(--forest-deep); }
  .tcard-more .arrow { transition: transform .2s ease; }
  .tcard-more:hover .arrow { transform: translateX(3px); }

  .bio-modal { position: fixed; inset: 0; z-index: 300; display: grid; place-items: center; padding: 24px; }
  .bio-modal[hidden] { display: none; }
  .bio-backdrop { position: absolute; inset: 0; background: rgba(12,11,8,.72); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); }
  .bio-panel { position: relative; width: min(440px, 92vw); aspect-ratio: 4 / 5; max-height: 86vh; border-radius: var(--r-lg); overflow: hidden; background-size: cover; background-position: 60% center; box-shadow: var(--shadow-lg); animation: bioIn .3s ease; }
  @keyframes bioIn { from { opacity: 0; transform: translateY(12px) scale(.98); } }
  .bio-scrim { position: absolute; inset: 0; background: linear-gradient(to top, rgba(10,9,7,.95) 4%, rgba(10,9,7,.75) 38%, rgba(10,9,7,.12) 72%, transparent 100%); }
  .bio-content { position: absolute; left: 0; right: 0; bottom: 0; padding: 24px 26px 28px; color: var(--cream-d); }
  .bio-name { font-size: 1.5rem; font-weight: 600; line-height: 1.1; }
  .bio-role { color: var(--brass-bright); font-size: .72rem; font-weight: 600; text-transform: uppercase; letter-spacing: .1em; margin: 6px 0 12px; }
  .bio-content p { color: var(--cream-muted); font-size: .92rem; line-height: 1.6; }
  .bio-close { position: absolute; top: 12px; right: 12px; z-index: 2; width: 34px; height: 34px; border-radius: 50%; border: 0; cursor: pointer; background: rgba(255,255,255,.18); color: #fff; font-size: .95rem; line-height: 1; backdrop-filter: blur(4px); }
  .bio-close:hover { background: rgba(255,255,255,.3); }
</style>

<script>
  (function () {
    const close = () => { document.querySelectorAll('.bio-modal').forEach((m) => { m.hidden = true; }); document.body.style.overflow = ''; };
    document.querySelectorAll('[data-bio]').forEach((b) => b.addEventListener('click', () => {
      const m = document.getElementById('bio-' + b.getAttribute('data-bio'));
      if (m) { m.hidden = false; document.body.style.overflow = 'hidden'; }
    }));
    document.querySelectorAll('[data-close]').forEach((c) => c.addEventListener('click', close));
    addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  })();
</script>
