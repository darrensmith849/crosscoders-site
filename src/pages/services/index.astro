---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ctas, products } from '../../lib/content';

const icons: Record<string, string> = {
  app: '<svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18M8 21h8"/></svg>',
  web: '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>',
  agent: '<svg viewBox="0 0 24 24"><rect x="4" y="7" width="16" height="12" rx="3"/><path d="M12 7V4M9 13h.01M15 13h.01"/></svg>',
  chat: '<svg viewBox="0 0 24 24"><path d="M21 12a8 8 0 0 1-11.5 7.2L4 20l1-4.5A8 8 0 1 1 21 12z"/></svg>',
  auto: '<svg viewBox="0 0 24 24"><path d="M4 7h10a4 4 0 0 1 0 8H8a4 4 0 0 0 0 8"/><circle cx="18" cy="7" r="2.4"/><circle cx="6" cy="19" r="2.4"/></svg>',
  code: '<svg viewBox="0 0 24 24"><path d="M8 9l-4 3 4 3M16 9l4 3-4 3M13 6l-2 12"/></svg>',
};
---

<BaseLayout
  title="What we build — apps, websites, AI agents & automation | CrossCoders"
  description="Apps, websites, AI agents, chatbots, automation and custom software for churches, ministries and mission-driven businesses. One senior team, built with AI."
>
  <section class="ph">
    <div class="wrap">
      <span class="eyebrow center">What we build</span>
      <h1 class="serif">Everything your mission needs built, in one place.</h1>
      <p class="sub">Apps, websites, AI agents, chatbots, automation and custom software — one senior team, supercharged by AI.</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href={ctas.primary.href}>{ctas.primary.label} <span class="arrow">→</span></a>
        <a class="btn btn-ghost" href={ctas.secondary.href}>{ctas.secondary.label}</a>
      </div>
    </div>
  </section>

  <section class="sec" style="padding-top:1rem">
    <div class="wrap">
      <div class="grid3">
        {products.map((p) => (
          <a class="card" href={`/services/${p.slug}`}>
            <div class="ic"><Fragment set:html={icons[p.icon]} /></div>
            <h3 class="serif">{p.name}</h3>
            <p>{p.blurb}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="sec cta">
    <div class="wrap">
      <h2 class="serif">Not sure where to start?</h2>
      <p>Tell us the problem — we'll tell you the right build. The first call is free.</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href={ctas.primary.href}>{ctas.primary.label} <span class="arrow">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
