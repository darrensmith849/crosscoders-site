---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ChurchArt from '../../../components/ChurchArt.astro';
import JourneyStrip from '../../../components/JourneyStrip.astro';
import QueueGrid from '../../../components/QueueGrid.astro';
import { queue, stageMeta, type QueueChurch } from '../../../lib/content';

export function getStaticPaths() {
  return queue.map((c) => ({ params: { slug: c.slug }, props: { church: c } }));
}
interface Props { church: QueueChurch }
const { church: c } = Astro.props;
const R = (n: number) => 'R' + n.toLocaleString('en-ZA');
const shipped = c.stage === 'shipped';
const amounts = [100, 250, 500, 1000];
const others = queue.filter((x) => x.slug !== c.slug).slice(0, 3);
---
<BaseLayout
  title={`${c.name} — ${c.kind} in our queue | CrossCoders Foundation`}
  description={c.tagline}
>
  <section class="qhero">
    <div class="wrap qhero-in">
      <div class="qhero-art">
        {c.image ? <img src={c.image} alt={c.name} /> : <ChurchArt kind={c.art} />}
      </div>

      <!-- Campaign card: bar → raised → title → description → button → quick amounts -->
      <div class="qcard" data-slug={c.slug} data-goal={c.goal}>
        <div class="qcard-top">
          <a class="qback" href="/foundation/queue">← Funded projects</a>
          <span class={`qpill qpill-${stageMeta[c.stage].tone}`}>{stageMeta[c.stage].label}</span>
        </div>

        <div class="qbar lg"><span data-bar style="width:0%"></span></div>

        <div class="qcard-raised">
          <b data-raised>{R(0)}</b>
          <span>raised of {R(c.goal)} &nbsp;·&nbsp; <b data-backers>0</b> backers</span>
        </div>

        <h1 class="serif qcard-title">{c.name}</h1>
        <p class="qcard-meta">{c.kind} · {c.region}</p>
        <p class="qcard-desc">{c.tagline}</p>

        {shipped ? (
          <div class="qcard-done">✓ Fully funded — live and theirs to keep.</div>
        ) : (
          <div>
            <a class="btn btn-primary qcard-cta" href={`/give?project=${c.slug}`}>Fund this build <span class="arrow">→</span></a>
            <div class="qcard-amts">
              {amounts.map((a) => (
                <a class="qcard-amt" href={`/give?project=${c.slug}&amount=${a}`}>{R(a)}</a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="psec">
    <div class="wrap qdetail">
      <article class="qstory">
        <span class="eyebrow">Their story</span>
        {c.story.map((p) => <p>{p}</p>)}
        <div class="colh" style="margin-top:26px">What this build gives them</div>
        <ul class="ulist">{c.need.map((n) => <li>{n}</li>)}</ul>
        <div class="qoutcome"><b>Where it gets them —</b> {c.outcome}</div>
      </article>

      <aside class="qpanel" data-slug={c.slug} data-name={c.name}>
        <div class="qbens">
          <div class="colh">Benefactors</div>
          <div class="qbens-list" data-benslist>
            <p class="qbens-empty">{shipped ? 'Funded by supporters like you.' : 'Be the first to back this build.'}</p>
          </div>
        </div>

        <form class="qfollow" data-followform>
          <input type="text" name="hp_check" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px" aria-hidden="true" data-1p-ignore data-lpignore="true" data-form-type="other" />
          <div class="colh">Follow this build</div>
          <p class="qfollow-p">Get an email as {c.name} moves from funded → building → launched.</p>
          <div class="qfollow-row">
            <input name="email" type="email" placeholder="you@email.com" required />
            <button class="btn btn-ghost" type="submit">Follow</button>
          </div>
        </form>
      </aside>
    </div>
  </section>

  <section class="psec oak">
    <div class="wrap">
      <span class="eyebrow center">Where {c.name} is on the journey</span>
      <h2 class="serif jhead">The path of this build.</h2>
      <JourneyStrip current={c.stage} onWood={true} />
    </div>
  </section>

  <section class="psec" style="background:var(--paper);border-top:1px solid var(--line)">
    <div class="wrap">
      <span class="eyebrow">More funded projects</span>
      <h2 class="serif" style="margin:16px 0 28px;font-size:clamp(1.7rem,3vw,2.2rem)">Other churches you could help.</h2>
      <QueueGrid items={others} />
    </div>
  </section>

  <style>
    .qcard { background: var(--linen); border: 1px solid var(--line); border-radius: var(--r-lg); box-shadow: var(--shadow); padding: clamp(22px, 3vw, 30px); align-self: start; }
    .qcard-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 18px; }
    .qcard-top .qback { margin: 0; }
    .qcard-top .qpill { position: static; }
    .qcard .qbar.lg { height: 12px; }
    .qcard-raised { margin-top: 16px; }
    .qcard-raised b[data-raised] { font-size: clamp(1.9rem, 4vw, 2.5rem); color: var(--forest-deep); font-family: Georgia, serif; line-height: 1; }
    .qcard-raised span { display: block; margin-top: 7px; font-size: .95rem; color: var(--ink-soft); }
    .qcard-raised span b { color: var(--ink); }
    .qcard-title { font-size: clamp(1.6rem, 3.2vw, 2.1rem); margin: 22px 0 0; }
    .qcard-meta { font-size: .85rem; color: var(--ink-mute); text-transform: uppercase; letter-spacing: .03em; margin: 8px 0 0; }
    .qcard-desc { font-size: 1.02rem; color: var(--ink-soft); line-height: 1.6; margin: 12px 0 0; }
    .qcard-cta { width: 100%; justify-content: center; margin-top: 22px; font-size: 1.05rem; }
    .qcard-amts { display: grid; grid-template-columns: repeat(4, 1fr); gap: 9px; margin-top: 12px; }
    .qcard-amt { text-align: center; font-weight: 500; font-size: .98rem; color: var(--ink); background: var(--paper); border: 1px solid var(--line-strong); border-radius: 11px; padding: 11px 4px; text-decoration: none; transition: border-color .15s, color .15s, transform .15s; }
    .qcard-amt:hover { border-color: var(--forest); color: var(--forest-deep); transform: translateY(-2px); }
    .qcard-done { margin-top: 22px; color: var(--forest-deep); font-weight: 500; background: rgba(19,178,74,.08); border: 1px solid rgba(19,178,74,.25); border-radius: 11px; padding: 13px 16px; text-align: center; }

    .qbens { margin-bottom: 24px; }
    .qbens-list { margin-top: 10px; display: flex; flex-direction: column; gap: 9px; }
    .qbens-empty { color: var(--ink-mute); font-size: .9rem; font-style: italic; margin: 0; }
    .qben { display: flex; align-items: center; gap: 9px; font-size: .92rem; color: var(--ink); }
    .qben-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--forest); flex: 0 0 auto; }
    .qben-biz { color: var(--ink-mute); font-size: .82rem; }
    .qben-anon { color: var(--ink-mute); font-size: .88rem; padding-left: 17px; }
    @media (max-width: 480px) { .qcard-amts { grid-template-columns: repeat(2, 1fr); } }
  </style>

  <script>
    (async function () {
      const card = document.querySelector('.qcard[data-slug]');
      const slug = card && card.getAttribute('data-slug');
      if (!slug) return;
      const goal = Number(card.getAttribute('data-goal')) || 0;
      try {
        const r = await fetch('/api/paystack/benefactors?project=' + encodeURIComponent(slug));
        const d = await r.json();
        const raised = (d.raisedCents || 0) / 100;
        const raisedEl = card.querySelector('[data-raised]');
        const backersEl = card.querySelector('[data-backers]');
        const barEl = card.querySelector('[data-bar]');
        if (raisedEl) raisedEl.textContent = 'R' + Math.round(raised).toLocaleString('en-ZA');
        if (backersEl) backersEl.textContent = String(d.total || 0);
        if (barEl && goal) barEl.style.width = Math.min(100, Math.round((raised / goal) * 100)) + '%';

        const list = document.querySelector('[data-benslist]');
        if (list && d.total > 0) {
          list.innerHTML = '';
          (d.benefactors || []).forEach((b) => {
            const row = document.createElement('div'); row.className = 'qben';
            const dot = document.createElement('span'); dot.className = 'qben-dot';
            const nm = document.createElement('span'); nm.textContent = b.displayName || '';
            row.appendChild(dot); row.appendChild(nm);
            if (b.giverType === 'business') { const bz = document.createElement('span'); bz.className = 'qben-biz'; bz.textContent = '· business'; row.appendChild(bz); }
            list.appendChild(row);
          });
          if (d.anonymous > 0) {
            const row = document.createElement('div'); row.className = 'qben-anon';
            row.textContent = '+ ' + d.anonymous + ' anonymous ' + (d.anonymous === 1 ? 'benefactor' : 'benefactors');
            list.appendChild(row);
          }
        }
      } catch (e) {}
    })();

    (function () {
      const form = document.querySelector('[data-followform]');
      if (!form) return;
      const panel = form.closest('.qpanel');
      const slug = (panel && panel.getAttribute('data-slug')) || '';
      const name = (panel && panel.getAttribute('data-name')) || '';
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('button[type=submit]');
        const data = Object.fromEntries(new FormData(form).entries());
        data.intent = 'follow'; data.church = slug; data.churchName = name; data.source = 'Queue follow — ' + name;
        const orig = btn.innerHTML; btn.disabled = true; btn.textContent = 'Sending…';
        try {
          const r = await fetch('/api/pledge', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(data) });
          const j = await r.json().catch(() => ({}));
          if (!r.ok || !j.ok) throw new Error();
          form.outerHTML = '<div class="apply-done"><h3 class="serif">You’re following ' + name + '.</h3><p>We’ll email you as this build moves forward — funded, building, launched.</p></div>';
        } catch {
          btn.disabled = false; btn.innerHTML = orig;
          let m = form.querySelector('.apply-err');
          if (!m) { m = document.createElement('p'); m.className = 'apply-err'; btn.insertAdjacentElement('afterend', m); }
          m.textContent = 'Sorry — something went wrong. Please email daniel@crosscoders.co.za and we’ll sort it out.';
        }
      });
    })();
  </script>
</BaseLayout>
