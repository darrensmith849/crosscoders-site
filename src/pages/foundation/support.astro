---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { brand } from '../../lib/content';
---

<BaseLayout title="Support the Kingdom Come Foundation — fund free software for churches" description="Donate, sponsor a build for a specific church, partner or volunteer — and help put world-class tools in the hands of under-resourced churches.">
  <PageHero eyebrow="The Foundation" title="Support the mission." sub="Your support multiplies — senior craft and AI mean more software per gift, in the hands of churches who need it most." cta={false} />

  <section class="psec">
    <div class="wrap prose">
      <span class="eyebrow">Why it goes further</span>
      <p style="margin-top:18px;font-size:1.18rem;color:var(--ink-soft);line-height:1.75">A gift here stretches further than a normal donation: because we pair senior craft with AI, every rand funds more finished software. You’re not buying hours — you’re funding outcomes for real churches.</p>
    </div>
  </section>

  <section class="psec" style="background:var(--paper);border-top:1px solid var(--line);border-bottom:1px solid var(--line)">
    <div class="wrap">
      <span class="eyebrow">Three ways to give</span>
      <h2 class="serif" style="margin:16px 0 28px;font-size:clamp(1.9rem,3.6vw,2.6rem)">Build something that lasts.</h2>
      <div class="paths">
        <div class="card"><h3 class="serif">Donate</h3><p>One-off or monthly — every gift funds free builds for churches.</p></div>
        <div class="card"><h3 class="serif">Sponsor a build</h3><p>Fund a free website, app or system for a specific, named church.</p></div>
        <div class="card"><h3 class="serif">Partner or volunteer</h3><p>Networks, sponsors, and skilled volunteers — multiply the impact.</p></div>
      </div>
      <div class="note" style="margin-top:24px"><b>Online giving is live.</b> <a href="/give" style="color:var(--forest-deep)">Give securely by card</a> in under a minute — or use the EFT details below. Want to partner or volunteer? Tell us below.</div>
    </div>
  </section>

  <section class="psec oak">
    <div class="wrap">
      <span class="eyebrow">Give now by EFT</span>
      <h2 class="serif" style="margin:16px 0 8px;font-size:clamp(1.9rem,3.6vw,2.6rem)">Prefer a direct transfer?</h2>
      <p style="color:var(--ink-soft);max-width:560px;margin-bottom:24px">Prefer a direct bank transfer? You can support a build straight away by EFT.</p>
      <div class="eft">
        <h4>Banking details</h4>
        <dl>
          <dt>Account name</dt><dd>Kingdom Come Foundation</dd>
          <dt>Bank</dt><dd>First National Bank (FNB)</dd>
          <dt>Account type</dt><dd>Cheque / Current</dd>
          <dt>Account number</dt><dd class="mono">62925911861</dd>
          <dt>Branch code</dt><dd class="mono">250 655</dd>
          <dt>SWIFT (international)</dt><dd class="mono">FIRNZAJJ</dd>
        </dl>
        <div class="eft-ref"><b>Reference:</b> use your own name for general giving, or a church's name to direct your gift to that build. Email <a href={brand.contactHref} style="color:var(--forest-deep)">{brand.email}</a> with your proof of payment and we'll send a thank-you.</div>
      </div>
    </div>
  </section>

  <section class="psec">
    <div class="wrap formwrap">
      <form data-supportform novalidate>
        <input type="text" name="hp_check" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px" aria-hidden="true" data-1p-ignore data-lpignore="true" data-form-type="other" />
        <div class="field"><label>Your name *</label><input name="name" required /></div>
        <div class="field"><label>Organisation (if any)</label><input name="org" /></div>
        <div class="field"><label>Email *</label><input name="email" type="email" required /></div>
        <div class="field"><label>How would you like to help?</label><select name="interest"><option>Donate</option><option>Sponsor a build</option><option>Partner</option><option>Volunteer my skills</option></select></div>
        <div class="field"><label>Message</label><textarea name="message"></textarea></div>
        <button class="btn btn-primary" type="submit">Get in touch <span class="arrow">→</span></button>
      </form>
      <aside class="sidecard">
        <h4>Where it goes</h4>
        <p style="font-size:.9rem;color:var(--ink-soft);line-height:1.6">Your support funds free and subsidised builds for under-resourced churches and ministries. We’re committed to being clear about how funds are used and what gets built.</p>
      </aside>
    </div>
  </section>

  <script>
    import { api } from '../../lib/api';
    const f = document.querySelector('[data-supportform]');
    if (f) {
      f.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = f.querySelector('button[type=submit]');
        const data = Object.fromEntries(new FormData(f).entries());
        if (data.interest) data.need = data.interest;
        data.source = 'Foundation support form';
        const orig = btn.innerHTML; btn.disabled = true; btn.textContent = 'Sending…';
        try {
          const r = await fetch(api('/api/support'), { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(data) });
          const j = await r.json().catch(() => ({}));
          if (!r.ok || !j.ok) throw new Error();
          f.innerHTML = '<div class="apply-done"><h3 class="serif">Thank you — we\'ll be in touch.</h3><p>We\'ve got your message and will reply by email. Thank you for backing the mission.</p></div>';
        } catch {
          btn.disabled = false; btn.innerHTML = orig;
          let m = f.querySelector('.apply-err');
          if (!m) { m = document.createElement('p'); m.className = 'apply-err'; btn.insertAdjacentElement('afterend', m); }
          m.textContent = 'Sorry — something went wrong. Please email daniel@crosscoders.co.za and we\'ll sort it out.';
        }
      });
    }
  </script>
</BaseLayout>
