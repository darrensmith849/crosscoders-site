---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { brand } from '../lib/content';

interface Props {
  title?: string;
  description?: string;
  image?: string; // social share image (relative to site root)
}
const {
  title = `${brand.name} — ${brand.tagline}`,
  description = brand.description,
  image = '/og.png',
} = Astro.props;
const site = Astro.site ?? new URL('https://crosscoders.pages.dev');
const ogImage = new URL(image, site).href;
const canonical = new URL(Astro.url.pathname, site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#13B24A" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brand.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_ZA" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${brand.name} — ${brand.org}: free, quality software given to the church.`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${brand.name} — ${brand.org}`} />
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
    <script>import '../scripts/demos.js';</script>
  </body>
</html>
